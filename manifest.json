{
  "manifest_version": 3,
  "name": "Tab Manager",
  "version": "1.0",
  "description": "Tab manager with domain grouping",
  "permissions": [
    "tabs"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}